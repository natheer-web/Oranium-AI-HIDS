import time
import requests
import os

# ORANIUM AI-HIDS Configuration 
# إعدادات نظام أورانيوم الذكي لكشف التسلل
TELEGRAM_TOKEN = "YOUR_TELEGRAM_BOT_TOKEN_HERE"
TELEGRAM_CHAT_ID = "YOUR_TELEGRAM_CHAT_ID_HERE"
GEMINI_API_KEY = "YOUR_GEMINI_API_KEY_HERE"

def analyze_and_send(log_line):
    """
    Analyzes the log line using Gemini AI and sends a Telegram alert.
    يحلل سطر السجل باستخدام ذكاء جمناي ويرسل تنبيهاً عبر تيليجرام.
    """
    print(f"\n[*] Suspicious activity detected: {log_line}")
    
    # 1. AI Analysis via Google Gemini
    # 1. التحليل بالذكاء الاصطناعي عبر جوجل جمناي
    url_gemini = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent?key={GEMINI_API_KEY}"
    payload_gemini = {
        "contents": [{"parts": [{"text": f"You are a SOC Analyst at ORANIUM. Briefly summarize this Linux security log in one professional Arabic sentence: {log_line}"}]}]
    }
    
    ai_text = "Alert: Failed login attempt detected by ORANIUM HIDS."
    try:
        res = requests.post(url_gemini, json=payload_gemini, timeout=10)
        res_json = res.json()
        
        if 'candidates' in res_json:
            ai_text = res_json['candidates'][0]['content']['parts'][0]['text']
        else:
            error_msg = res_json.get('error', {}).get('message', 'Unexpected response')
            ai_text = f"Security Alert: Failed login attempt (AI Analysis skipped: {error_msg})"
    except Exception as e:
        print(f"[-] Failed to connect to AI server: {e}")

    # 2. Telegram Alert Transmission
    # 2. إرسال التنبيه عبر تيليجرام
    url_telegram = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
    payload_telegram = {
        "chat_id": TELEGRAM_CHAT_ID, 
        "text": f"🚨 **ORANIUM Security Alert** 🚨\n\n{ai_text}", 
        "parse_mode": "Markdown"
    }
    
    try:
        requests.post(url_telegram, json=payload_telegram, timeout=10)
        print("[+] Security alert sent to Telegram successfully! 🚀")
    except Exception as e:
        print(f"[-] Network Error: Could not send to Telegram: {e}")

def watch_log():
    """
    Monitors the auth.log file in real-time.
    يراقب ملف السجلات بالوقت الفعلي.
    """
    print("[*] ORANIUM HIDS is active and monitoring the server in the background...")
    try:
        with open("/var/log/auth.log", "r") as f:
            f.seek(0, os.SEEK_END)
            while True:
                line = f.readline()
                if not line:
                    time.sleep(1)
                    continue
                
                if "Failed password" in line or "authentication failure" in line:
                    analyze_and_send(line.strip())
                    
    except PermissionError:
        print("[-] Error: Script requires Root privileges. Please run with sudo.")
    except Exception as e:
        print(f"[-] Unexpected error occurred: {e}")

if __name__ == "__main__":
    watch_log()
